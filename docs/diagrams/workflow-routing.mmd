    q1 -->|"是"| q3{"Q3: 同时涉及前端?"}
    q1 -->|"否"| q2{"Q2: 涉及前端?"}

    q3 -->|"否"| wfA["工作流 A<br/><small>PM → Arch → Dev → QA</small>"]
    q3 -->|"是"| wfC["工作流 C<br/><small>PM → Arch → Dev + FE → QA</small>"]

    q2 -->|"否"| nonfunc["非功能性变更<br/><small>直接处理</small>"]
